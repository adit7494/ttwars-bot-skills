# TTWars Bot Configuration
# Copy this file to .env and fill in your values

# Server URL (without https://)
TTWARS_SERVER=unl7.ttwars.com

# Login credentials
TTWARS_USERNAME=your_username
TTWARS_PASSWORD=your_password

# Bot behavior
POLL_INTERVAL_SECONDS=10
AUTO_ADVENTURE=true
AUTO_BUILD=true
HERO_PRODUCTION=crop

# Logging
LOG_LEVEL=INFO
